@{
}
@if(Context.User.Identity.IsAuthenticated == false)
{
    //EFECTO OPTICO DE LOGIN
    <li class="nav-link  text-info">
        <a class="nav-link"
           asp-controller="Empleados"
           asp-action="PerfilEmpleado">
            Log In
        </a>
    </li>
}
else
{
    <li class="nav-link  text-info">
        <a class="nav-link"
           asp-controller="Managed"
           asp-action="LogOut">
            Log Out
            <span style="color:blue">@Context.User.Identity.Name</span>
        </a>
    </li>
    <li class="nav-link  text-info">
        <a class="nav-link"
           asp-controller="Empleados"
           asp-action="PerfilEmpleado">
            Log In
        </a>
    </li>
}